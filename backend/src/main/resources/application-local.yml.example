# 使用方式：复制本文件为 application-local.yml，再填写密码与密钥。
# application-local.yml 已被 backend/.gitignore 忽略，勿提交仓库。

spring:
  datasource:
    url: jdbc:mysql://127.0.0.1:3306/loseweight?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false
    username: root
    password: 在此填写本地 MySQL 密码

wechat:
  miniapp:
    app-id: wx18b3c99724695bb8
    # 微信公众平台 → 开发 → 开发管理 → AppSecret（仅服务端 code2session 使用）
    app-secret: 在此填写小程序 AppSecret

aliyun:
  food:
    host: https://jmfdcl.market.alicloudapi.com
    path: /food/calories/query
    # 云市场 → 我的服务 → AppCode
    appcode: 在此填写阿里云食物识别 AppCode

# HS256 密钥，至少 32 个字符，勿提交真实值
app:
  jwt:
    secret: 在此填写至少32位随机字符串作为JWT密钥
