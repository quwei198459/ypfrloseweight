        {
          "type": "frame",
          "id": "sDGiP",
          "name": "FatLossTrendPage",
          "context": "【页面】FatLossTrendPage（减脂趋势）\n【入口】UserHomePage → currentWeightCard（当前体重块）→ 本页\n【导航】仅系统二级页导航：trendNavBar\n【交互】initialWeightBlock（标签/数值/编辑图标区域）→ InitialWeightEditModal\n【交互】currentWeightBlock → CurrentWeightEditModal\n【交互】targetWeightBlock → TargetWeightEditModal\n【结构】trendNavBar / summaryCard（含顶部装饰）/ trendChartCard / recordWeightButtonWrap",
          "clip": true,
          "width": 375,
          "height": 1020,
          "fill": "#EFEFEF",
          "layout": "vertical",
          "padding": [
            0,
            14
          ],
          "children": [
            {
              "type": "frame",
              "id": "XNtuC",
              "name": "trendNavBar",
              "context": "【系统导航】微信小程序二级页导航区（非业务自定义头部）",
              "width": "fill_container",
              "height": 88,
              "padding": [
                50,
                0,
                6,
                0
              ],
              "justifyContent": "space_between",
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "6kSUI",
                  "name": "navBack",
                  "fill": "#1a1a1a",
                  "content": "‹",
                  "fontFamily": "Inter",
                  "fontSize": 26,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "EPfJx",
                  "name": "navTitle",
                  "fill": "#1a1a1a",
                  "content": "减脂趋势",
                  "fontFamily": "Inter",
                  "fontSize": 17,
                  "fontWeight": "600"
