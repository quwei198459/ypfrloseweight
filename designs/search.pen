    {
      "type": "note",
      "id": "7z766",
      "x": 20,
      "y": 1151,
      "name": "component-tree-spec",
      "width": 1900,
      "height": 220,
      "content": "【search-page-empty】search-header-area → search-input-row → search-input-bar + cancel-text-button；decorative-top-wave(wave-bump-*)；empty-state(empty-illustration, empty-text)\n【search-page-result】search-header-area + scroll-list-container → food-result-item×N\n【food-record-popup】popup-mask + popup-panel；quantity-input-row；number-keyboard → number-grid（4×key-row 等高40px，gap4，末行 key-dot(1列) + key-0(占2列宽)）+ action-column（总高172= delete-button 56 + gap6 + confirm-button 110，与 number-grid 顶底对齐）\n【record-success-page】\n【daily-record-page】\n【标题】热量查询/记录成功/每日饮食记录 为系统导航，不在画板绘制。"
    }
  ]
}